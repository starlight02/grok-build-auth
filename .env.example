# Turnstile backends: auto | drission | camoufox | browser | safari
# auto (default if unset) → drission when DrissionPage is installed, else browser
# TURNSTILE_SOLVER=auto
TURNSTILE_SOLVER=drission
# Camoufox optional backend (requires: pip install camoufox && camoufox fetch)
# TURNSTILE_SOLVER=camoufox
# Playwright fallback:
# TURNSTILE_SOLVER=browser
#
# Headed window is more reliable against CF for drission/camoufox (default 0).
# Playwright defaults to headless=1 unless you set this.
# TURNSTILE_HEADLESS=0
# Headed quiet mode (minimize + optional off-screen):
# TURNSTILE_OFFSCREEN=1
# TURNSTILE_MINIMIZED=1
# TURNSTILE_WINDOW_POSITION=-32000,-3200
#
# --- Token pool (DEFAULT ON) ---
# Background mint; signup threads only consume tokens.
# Size / target / minters auto-scale from run.py -t when unset.
# TURNSTILE_POOL=1
# TURNSTILE_POOL=0                 # disable pool → per-thread mint
# TURNSTILE_POOL_SIZE=4            # hard cap (auto: max(2, -t), cap 32)
# TURNSTILE_POOL_TARGET=2          # idle ready stock; pause when satisfied
# TURNSTILE_POOL_MINTERS=1         # auto: ceil(-t/4) cap 4; Safari forced 1
# TURNSTILE_TOKEN_MAX_AGE=200      # discard older pooled tokens
# TURNSTILE_PAUSE_FILE=/tmp/grok-turnstile.pause  # touch=pause mint/click
#
# Only used when pool is OFF (auto follows -t, cap 8):
# TURNSTILE_PARALLEL=4
#
# Camoufox without a real display:
# TURNSTILE_HEADLESS=virtual
# Manual checkbox (Playwright only; forces headed):
# TURNSTILE_INTERACTIVE=1
# Playwright channel (auto-selects system chrome when available):
# TURNSTILE_BROWSER_CHANNEL=chrome
# Hard timeout per solve (seconds; drission default 30, others 60):
# TURNSTILE_TIMEOUT=30
# Warm browser / warm-page reuse (default 1):
# TURNSTILE_BROWSER_REUSE=1
# Verbose solver logs:
# TURNSTILE_DEBUG=1
#
# CLI defaults worth knowing:
#   python run.py -n 20          # implies -t 4 + pool on
#   python run.py -n 20 -t 8     # pool auto → size=8 minters=2

# --- Multi-channel mail (DEFAULT: -e auto uses all configured) ---
# MAIL_BACKENDS=tempmail,yyds     # optional override of -e auto
# MAIL_CHANNEL_WEIGHTS=tempmail:100,yyds:40,cloudflare:60
#   higher = preferred when a free slot exists; lower = overflow only
# MAIL_CHANNEL_CAPACITY=tempmail:3,yyds:2
#   max concurrent creates per channel before overflow (tempmail free default 1)
# Single channel: -e yyds | -e tempmail  → solo mode (no overflow needed)
# New backends: register_channel(ChannelSpec(...)) in mail_channels / plugin
# Channels auto-detected when credentials exist:
#   tempmail   always (free) / faster with TEMPMAIL_API_KEY
#   yyds       needs YYDS_API_KEY or YYDS_JWT
#   cloudflare needs CLOUDFLARE_* + ALIAS_MAIL_DOMAINS
#
# Optional — Tempmail.lol Plus/Ultra key (free tier needs no key)
TEMPMAIL_API_KEY=
# Free tier (no key): process-wide create pacing ≈20/min to reduce 429s
# TEMPMAIL_FREE_CREATE_INTERVAL=3
# Wait this many seconds for the code, then rotate to a fresh inbox
# MAIL_CODE_TIMEOUT=30
# How many fresh inboxes to try (total wait ≈ timeout × attempts)
# MAIL_MAX_ATTEMPTS=3
# --- Mailbox pool (DEFAULT ON) ---
# Pre-create inboxes in parallel with turnstile mint; multi-channel LB inside.
# MAIL_POOL=1
# MAIL_POOL=0                 # disable → create per registration
# MAIL_POOL_SIZE=4            # hard cap (auto from -t)
# MAIL_POOL_TARGET=2          # idle ready stock
# MAIL_POOL_MINTERS=1         # create threads (auto: ceil(-t/4) cap 4)
# MAIL_POOL_MAX_AGE=600       # discard older pooled inboxes (seconds)

# Optional — YYDS mailbox (-e yyds|auto); API from grok_reg (maliapi.215.im)
# YYDS_API_KEY=
# YYDS_JWT=
# YYDS_API_BASE=https://maliapi.215.im/v1
# Domain allow-list (comma-separated). Empty = ALL verified domains, load-balanced.
# YYDS_DOMAINS=example.com,other.org

# Optional — Cloudflare D1 alias mailbox (-e cloudflare)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DB_ID=
# Comma-separated domains you control (must match your D1 mail schema)
ALIAS_MAIL_DOMAINS=mail.example.com
# ALIAS_EXTRA_DOMAINS=

# Optional — where to write CLIProxyAPI-compatible auth JSON
# Default: ./cliproxyapi_auth
# CLIPROXYAPI_AUTH_DIR=/path/to/CLIProxyAPI/data/auth

# Optional HTTP(S) proxy — single
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
#
# Proxy pool file (preferred for large lists): one URL per line, host-IP geo
# filters to PROXY_REGION, preflight drops dead nodes, rotate + retry on fail.
# PROXY_POOL_FILE=./proxies.txt
# PROXY_REGION=us
# PROXY_POOL_SCOPE=same_region   # default; use all to skip region filter
# PROXY_GEO_MODE=host            # host (fast) | exit (slow through-proxy)
# PROXY_GEO_WORKERS=16
# PROXY_GEO_TIMEOUT=12
# PROXY_GEO_CACHE=./.proxy_geo_cache.json
# PROXY_GEO_REFRESH=0            # 1 = ignore cache, re-probe
# PROXY_PREFLIGHT=1              # default on for multi-proxy pools
# PROXY_PREFLIGHT_WORKERS=16
# PROXY_PREFLIGHT_TIMEOUT=8
# PROXY_RETRY=8                  # per-account rotates on transport fail
# Optional inline list (small only):
# PROXY_POOL=http://a:1,http://b:1

# Turnstile backends: auto | drission | camoufox | browser
# auto (default if unset) → drission when DrissionPage is installed, else browser
# TURNSTILE_SOLVER=auto
TURNSTILE_SOLVER=drission
# Camoufox optional backend (requires: pip install camoufox && camoufox fetch)
# TURNSTILE_SOLVER=camoufox
# Playwright fallback:
# TURNSTILE_SOLVER=browser
#
# Headed window is more reliable against CF for drission/camoufox (default 0).
# Playwright defaults to headless=1 unless you set this.
# TURNSTILE_HEADLESS=0
# Headed quiet mode (minimize + optional off-screen):
# TURNSTILE_OFFSCREEN=1
# TURNSTILE_MINIMIZED=1
# TURNSTILE_WINDOW_POSITION=-32000,-3200
# Concurrent Turnstile mints (default 2; each slot = thread-local Chrome for drission)
# TURNSTILE_PARALLEL=2
# Camoufox without a real display:
# TURNSTILE_HEADLESS=virtual
# Manual checkbox (Playwright only; forces headed):
# TURNSTILE_INTERACTIVE=1
# Playwright channel (auto-selects system chrome when available):
# TURNSTILE_BROWSER_CHANNEL=chrome
# Hard timeout per solve (seconds; drission default 30, others 60):
# TURNSTILE_TIMEOUT=30
# Warm browser reuse (default 1; drission is thread-local):
# TURNSTILE_BROWSER_REUSE=1
# Verbose solver logs:
# TURNSTILE_DEBUG=1
# Note: run.py bounds Turnstile with TURNSTILE_PARALLEL (default 2).

# Optional — Tempmail.lol Plus/Ultra key (free tier needs no key)
TEMPMAIL_API_KEY=
# Wait this many seconds for the code, then rotate to a fresh inbox
# MAIL_CODE_TIMEOUT=30
# How many fresh inboxes to try (total wait ≈ timeout × attempts)
# MAIL_MAX_ATTEMPTS=3

# Optional — Cloudflare D1 alias mailbox (-e cloudflare)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DB_ID=
# Comma-separated domains you control (must match your D1 mail schema)
ALIAS_MAIL_DOMAINS=mail.example.com
# ALIAS_EXTRA_DOMAINS=

# Optional — where to write CLIProxyAPI-compatible auth JSON
# Default: ./cliproxyapi_auth
# CLIPROXYAPI_AUTH_DIR=/path/to/CLIProxyAPI/data/auth

# Optional HTTP(S) proxy
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

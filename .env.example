# Turnstile: local browser only (Playwright Chrome/Chromium)
# TURNSTILE_SOLVER=browser
TURNSTILE_SOLVER=browser
# Default headless=1 uses system Chrome + --headless=new (no GUI needed).
# TURNSTILE_HEADLESS=1
# Headed window (visible Chrome):
# TURNSTILE_HEADLESS=0
# Manual checkbox click (forces headed):
# TURNSTILE_INTERACTIVE=1
# Auto-selects channel=chrome when headless and Chrome is installed.
# TURNSTILE_BROWSER_CHANNEL=chrome
# TURNSTILE_TIMEOUT=60
# Keep per-thread browser warm (default 1)
# TURNSTILE_BROWSER_REUSE=1
# Note: run.py serializes Turnstile with a global lock (CF rate-limits parallel solves).
# TURNSTILE_BROWSER_CONCURRENCY is only a secondary cap inside the solver.

# Optional — Tempmail.lol Plus/Ultra key (free tier needs no key)
TEMPMAIL_API_KEY=
# Wait this many seconds for the code, then rotate to a fresh inbox
# MAIL_CODE_TIMEOUT=30
# How many fresh inboxes to try (total wait ≈ timeout × attempts)
# MAIL_MAX_ATTEMPTS=3

# Optional — Cloudflare D1 alias mailbox (-e cloudflare)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DB_ID=
# Comma-separated domains you control (must match your D1 mail schema)
ALIAS_MAIL_DOMAINS=mail.example.com
# ALIAS_EXTRA_DOMAINS=

# Optional — where to write CLIProxyAPI-compatible auth JSON
# Default: ./cliproxyapi_auth
# CLIPROXYAPI_AUTH_DIR=/path/to/CLIProxyAPI/data/auth

# Optional HTTP(S) proxy
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

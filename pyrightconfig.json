{
  "include": [
    "run.py",
    "tools",
    "contrib/alias_mail",
    "xconsole_client",
    "tests"
  ],
  "exclude": [
    "**/__pycache__",
    "**/.ruff_cache",
    "logs",
    "tmp",
    "sso_output"
  ],
  "pythonVersion": "3.11",
  "venvPath": ".",
  "venv": ".venv",
  "typeCheckingMode": "basic",
  "reportMissingImports": "none",
  "reportMissingModuleSource": "none",
  "reportAttributeAccessIssue": "warning"
}
